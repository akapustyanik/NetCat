<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <SolidColorBrush x:Key="ProtocolEditorWindowBackgroundBrush" Color="#0B1220" />
    <SolidColorBrush x:Key="ProtocolEditorSurfaceBrush" Color="#111A2B" />
    <SolidColorBrush x:Key="ProtocolEditorSurfaceAltBrush" Color="#162235" />
    <SolidColorBrush x:Key="ProtocolEditorBorderBrush" Color="#253246" />
    <SolidColorBrush x:Key="ProtocolEditorMutedTextBrush" Color="#93A5BE" />
    <SolidColorBrush x:Key="ProtocolEditorStrongTextBrush" Color="#E8EEF7" />
    <SolidColorBrush x:Key="ProtocolEditorAccentBrush" Color="#4F8CFF" />
    <SolidColorBrush x:Key="ProtocolEditorAccentSoftBrush" Color="#264F8CFF" />
    <SolidColorBrush x:Key="ProtocolEditorScrollBarTrackBrush" Color="#1A2840" />
    <SolidColorBrush x:Key="ProtocolEditorScrollBarThumbBrush" Color="#4F8CFF" />
    <SolidColorBrush x:Key="ProtocolEditorScrollBarThumbBorderBrush" Color="#84B0FF" />
    <SolidColorBrush x:Key="ProtocolEditorScrollBarThumbHoverBrush" Color="#6C9DFF" />
    <SolidColorBrush x:Key="ProtocolEditorScrollBarThumbDragBrush" Color="#3D79E6" />

    <Style x:Key="ModuleTitle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorStrongTextBrush}" />
    </Style>

    <Style x:Key="ToolbarTextBlock" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorMutedTextBrush}" />
    </Style>

    <Style x:Key="DefButton" BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="{x:Type Button}">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="100" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorAccentBrush}" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
    </Style>

    <Style x:Key="SubtleButton" BasedOn="{StaticResource MaterialDesignOutlinedButton}" TargetType="{x:Type Button}">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="100" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorStrongTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProtocolEditorBorderBrush}" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
    </Style>

    <Style x:Key="DefTextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}" TargetType="{x:Type TextBox}">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorStrongTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorSurfaceAltBrush}" />
    </Style>

    <Style x:Key="MyOutlinedTextBox" BasedOn="{StaticResource DefTextBox}" TargetType="{x:Type TextBox}" />

    <Style x:Key="DefComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}" TargetType="{x:Type ComboBox}">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorStrongTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorSurfaceAltBrush}" />
    </Style>

    <Style x:Key="MyOutlinedTextComboBox" BasedOn="{StaticResource DefComboBox}" TargetType="{x:Type ComboBox}" />

    <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource MaterialDesignSwitchToggleButton}" />

    <Style TargetType="{x:Type Separator}" BasedOn="{StaticResource MaterialDesignSeparator}">
        <Setter Property="Margin" Value="0,10,0,10" />
        <Setter Property="Opacity" Value="0.45" />
    </Style>

    <Style x:Key="ProtocolEditorScrollBarTrackButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProtocolEditorRoundedScrollBarThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorScrollBarThumbBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProtocolEditorScrollBarThumbBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border
                        Margin="2"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ProtocolEditorScrollBarThumbHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ProtocolEditorScrollBarThumbDragBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="ProtocolEditorVerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Border
            Background="{DynamicResource ProtocolEditorScrollBarTrackBrush}"
            CornerRadius="7"
            SnapsToDevicePixels="True">
            <Track
                x:Name="PART_Track"
                Margin="1"
                IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource ProtocolEditorScrollBarTrackButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb MinHeight="40" Style="{StaticResource ProtocolEditorRoundedScrollBarThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource ProtocolEditorScrollBarTrackButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Border>
    </ControlTemplate>

    <ControlTemplate x:Key="ProtocolEditorHorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Border
            Background="{DynamicResource ProtocolEditorScrollBarTrackBrush}"
            CornerRadius="7"
            SnapsToDevicePixels="True">
            <Track
                x:Name="PART_Track"
                Margin="1"
                IsDirectionReversed="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand" Style="{StaticResource ProtocolEditorScrollBarTrackButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb MinWidth="40" Style="{StaticResource ProtocolEditorRoundedScrollBarThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand" Style="{StaticResource ProtocolEditorScrollBarTrackButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Border>
    </ControlTemplate>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorScrollBarTrackBrush}" />
        <Setter Property="Width" Value="14" />
        <Setter Property="Template" Value="{StaticResource ProtocolEditorVerticalScrollBarTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="14" />
                <Setter Property="Template" Value="{StaticResource ProtocolEditorHorizontalScrollBarTemplate}" />
            </Trigger>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="14" />
                <Setter Property="Height" Value="Auto" />
                <Setter Property="Template" Value="{StaticResource ProtocolEditorVerticalScrollBarTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DefContextMenu" TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorStrongTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProtocolEditorBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <sys:Double x:Key="MenuItemHeight"
                xmlns:sys="clr-namespace:System;assembly=mscorlib">36</sys:Double>

    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorStrongTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorSurfaceBrush}" />
        <Setter Property="Height" Value="{StaticResource MenuItemHeight}" />
    </Style>

    <Style TargetType="{x:Type DataGrid}" BasedOn="{StaticResource MaterialDesignDataGrid}">
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorStrongTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProtocolEditorBorderBrush}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ProtocolEditorBorderBrush}" />
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource ProtocolEditorBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource MaterialDesignDataGridRow}">
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorStrongTextBrush}" />
    </Style>

    <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorSurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorStrongTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProtocolEditorBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource MaterialDesignDataGridCell}">
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorStrongTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProtocolEditorBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorMutedTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource ProtocolEditorSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProtocolEditorBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border
                        x:Name="TabBorder"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ProtocolEditorAccentSoftBrush}" />
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ProtocolEditorAccentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ProtocolEditorStrongTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
