<reactiveui:ReactiveUserControl
    x:Name="Root"
    x:Class="v2rayN.Views.CheckUpdateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="clr-namespace:v2rayN.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:reactiveui="http://reactiveui.net"
    xmlns:vms="clr-namespace:ServiceLib.ViewModels;assembly=ServiceLib"
    d:DesignHeight="620"
    d:DesignWidth="920"
    x:TypeArguments="vms:CheckUpdateViewModel"
    AllowDrop="True"
    Background="{DynamicResource NetCatWindowBackgroundBrush}"
    Foreground="{DynamicResource NetCatStrongTextBrush}"
    Drop="OnRootDrop"
    PreviewDragOver="OnRootPreviewDragOver"
    mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

            <Style x:Key="UpdateTitleText" BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource NetCatStrongTextBrush}" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="UpdateBodyText" BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource NetCatMutedTextBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style x:Key="UpdatePrimaryButton" BasedOn="{StaticResource DefButton}" TargetType="{x:Type ButtonBase}">
                <Setter Property="MinWidth" Value="118" />
                <Setter Property="Height" Value="38" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>

            <Style x:Key="UpdateSecondaryButton" BasedOn="{StaticResource MaterialDesignOutlinedButton}" TargetType="{x:Type ButtonBase}">
                <Setter Property="FontSize" Value="{DynamicResource StdFontSize}" />
                <Setter Property="MinHeight" Value="40" />
                <Setter Property="MinWidth" Value="98" />
                <Setter Property="Padding" Value="14,9" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="TextBlock.LineHeight" Value="16" />
                <Setter Property="TextBlock.LineStackingStrategy" Value="BlockLineHeight" />
                <Setter Property="Foreground" Value="{DynamicResource NetCatStrongTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource NetCatSurfaceAltBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource NetCatWindowChromeBrush}" />
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>

            <Style x:Key="UpdateItemStyle" TargetType="{x:Type ListViewItem}">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,12" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListViewItem}">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="StatusBadgeBorder" TargetType="{x:Type Border}">
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="#1A5A6E86" />
                <Setter Property="BorderBrush" Value="#336B86A6" />
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ShowStatusLabel}" Value="False">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding StatusTone}" Value="success">
                        <Setter Property="Background" Value="#173A7C56" />
                        <Setter Property="BorderBrush" Value="#3370C28A" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding StatusTone}" Value="warning">
                        <Setter Property="Background" Value="#194D3B17" />
                        <Setter Property="BorderBrush" Value="#33D9A441" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding StatusTone}" Value="error">
                        <Setter Property="Background" Value="#193F1E23" />
                        <Setter Property="BorderBrush" Value="#33D36E7E" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding StatusTone}" Value="working">
                        <Setter Property="Background" Value="#1A253750" />
                        <Setter Property="BorderBrush" Value="#335B86B4" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="StatusBadgeText" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource NetCatStrongTextBrush}" />
            </Style>

            <Style x:Key="VersionCaptionText" BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource NetCatMutedTextBrush}" />
                <Setter Property="FontSize" Value="11" />
            </Style>

            <Style x:Key="VersionValueText" BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource NetCatStrongTextBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="UpdateScrollBarThumbStyle" TargetType="{x:Type Thumb}">
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Background" Value="{DynamicResource NetCatScrollBarThumbBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource NetCatScrollBarThumbBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Border
                                Margin="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="UpdateScrollBarTrackButtonStyle" TargetType="{x:Type RepeatButton}">
                <Setter Property="Focusable" Value="False" />
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                            <Border Background="Transparent" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <ControlTemplate x:Key="UpdateVerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
                <Grid Width="{TemplateBinding Width}" Background="Transparent">
                    <Border
                        Margin="3,2"
                        Background="{DynamicResource NetCatScrollBarTrackBrush}"
                        CornerRadius="8" />
                    <Track
                        x:Name="PART_Track"
                        Margin="2"
                        Focusable="False"
                        IsDirectionReversed="True">
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource UpdateScrollBarTrackButtonStyle}" />
                        </Track.DecreaseRepeatButton>
                        <Track.Thumb>
                            <Thumb MinHeight="44" Style="{StaticResource UpdateScrollBarThumbStyle}" />
                        </Track.Thumb>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource UpdateScrollBarTrackButtonStyle}" />
                        </Track.IncreaseRepeatButton>
                    </Track>
                </Grid>
            </ControlTemplate>

            <Style x:Key="UpdateScrollBarStyle" TargetType="{x:Type ScrollBar}">
                <Setter Property="Width" Value="14" />
                <Setter Property="Template" Value="{StaticResource UpdateVerticalScrollBarTemplate}" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="18"
            Background="{DynamicResource NetCatSurfaceBrush}"
            BorderBrush="{DynamicResource NetCatWindowChromeBrush}"
            BorderThickness="1"
            CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource UpdateTitleText}" Text="Обновления" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Style="{StaticResource UpdateBodyText}"
                        Text="Проверяйте версии модулей, открывайте релиз на GitHub и при необходимости устанавливайте NetCat из локального ZIP."
                        TextWrapping="Wrap" />
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Margin="18,0,0,0"
                    Padding="14,12"
                    Background="{DynamicResource NetCatSurfaceAltBrush}"
                    BorderBrush="{DynamicResource NetCatWindowChromeBrush}"
                    BorderThickness="1"
                    CornerRadius="14">
                    <StackPanel Width="250">
                        <TextBlock
                            Style="{StaticResource UpdateBodyText}"
                            Text="Нажмите кнопку `Из ZIP` у NetCat или перетащите релизный .zip-файл прямо в это окно."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Margin="0,18,0,18"
            Padding="16"
            Background="{DynamicResource NetCatSurfaceBrush}"
            BorderBrush="{DynamicResource NetCatWindowChromeBrush}"
            BorderThickness="1"
            CornerRadius="18">
            <ListView
                x:Name="lstCheckUpdates"
                Background="Transparent"
                BorderThickness="0"
                ItemContainerStyle="{StaticResource UpdateItemStyle}"
                ScrollViewer.CanContentScroll="False"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                common:SmoothScrollBehavior.IsEnabled="True"
                common:SmoothScrollBehavior.MouseWheelMultiplier="1.55">
                <ListView.Resources>
                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource UpdateScrollBarStyle}" />
                </ListView.Resources>
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="16"
                            Background="{DynamicResource NetCatSurfaceAltBrush}"
                            BorderBrush="{DynamicResource NetCatWindowChromeBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock
                                            DockPanel.Dock="Left"
                                            Style="{StaticResource ModuleTitle}"
                                            Text="{Binding DisplayName}" />
                                        <Border
                                            DockPanel.Dock="Right"
                                            Margin="12,0,0,0"
                                            Style="{StaticResource StatusBadgeBorder}">
                                            <TextBlock
                                                Style="{StaticResource StatusBadgeText}"
                                                Text="{Binding StatusLabel}" />
                                        </Border>
                                    </DockPanel>

                                    <WrapPanel Margin="0,12,0,0">
                                        <Border
                                            MinWidth="150"
                                            Margin="0,0,10,10"
                                            Padding="12,10"
                                            Background="{DynamicResource NetCatSurfaceBrush}"
                                            BorderBrush="{DynamicResource NetCatWindowChromeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource VersionCaptionText}" Text="Текущая версия" />
                                                <TextBlock Style="{StaticResource VersionValueText}" Text="{Binding CurrentVersion}" />
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            MinWidth="150"
                                            Margin="0,0,10,10"
                                            Padding="12,10"
                                            Background="{DynamicResource NetCatSurfaceBrush}"
                                            BorderBrush="{DynamicResource NetCatWindowChromeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Visibility="{Binding ShowLatestVersion, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource VersionCaptionText}" Text="Доступная версия" />
                                                <TextBlock Style="{StaticResource VersionValueText}" Text="{Binding LatestVersion}" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <TextBlock
                                        Foreground="{DynamicResource NetCatMutedTextBrush}"
                                        Text="{Binding Hint}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,10,0,0"
                                        Foreground="{DynamicResource NetCatStrongTextBrush}"
                                        Text="{Binding Remarks}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Margin="18,0,0,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">
                                    <Button
                                        Content="{Binding ActionLabel}"
                                        Command="{Binding ViewModel.UpdateModuleCmd, ElementName=Root}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource UpdatePrimaryButton}"
                                        Visibility="{Binding CanRunUpdate, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button
                                        Content="GitHub"
                                        Command="{Binding ViewModel.OpenReleaseCmd, ElementName=Root}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource UpdateSecondaryButton}"
                                        Visibility="{Binding CanOpenReleaseUrl, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button
                                        Content="Из ZIP"
                                        Command="{Binding ViewModel.InstallLocalPackageCmd, ElementName=Root}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource UpdateSecondaryButton}"
                                        Visibility="{Binding CanUseLocalPackage, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Border
            Grid.Row="2"
            Padding="16"
            Background="{DynamicResource NetCatSurfaceBrush}"
            BorderBrush="{DynamicResource NetCatWindowChromeBrush}"
            BorderThickness="1"
            CornerRadius="18">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock
                        Foreground="{DynamicResource NetCatStrongTextBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="NetCat update flow" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Style="{StaticResource UpdateBodyText}"
                        Text="Update проверяет GitHub Releases. Если сеть недоступна, используйте локальный ZIP-пакет релиза."
                        TextWrapping="Wrap" />
                </StackPanel>

                <WrapPanel
                    Margin="16,0,0,0"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal">
                    <Button
                        x:Name="btnCheckUpdate"
                        MinWidth="160"
                        Content="Update All"
                        IsDefault="True"
                        Style="{StaticResource UpdatePrimaryButton}" />
                </WrapPanel>
            </DockPanel>
        </Border>
    </Grid>
</reactiveui:ReactiveUserControl>
